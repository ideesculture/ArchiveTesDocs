{% extends '::mini.html.twig' %}

{% block overlay %}
    <!-- waiting div while ajax response -->
    <div class="overlay text-center" id="waitAjax"><br/><br/><br/>
        <h2 style="color:#fff;"><span class="fal fa-2x fa-spinner fa-spin"></span>&nbsp;&nbsp;Veuillez patienter, attente de la réponse du serveur !</h2>
    </div>
    <!-- B#25 Show Detailled information about statistics -->
    <div class="modal fade" id="DetailledInformationModal" tabindex="-1" role="dialog" aria-labelledby="DetailledInformationLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal">
                        <span aria-hidden="true">&times;</span>
                        <span class="sr-only">Close</span>
                    </button>
                    <h4 class="modal-title" id="DetailledInformationLabel">Informations complémentaires</h4>
                </div>
                <div class="modal-body" id="DetailledInformationContent">
                    &nbsp; <!-- Datas will be updated with javascript queries -->
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-default" data-dismiss="modal">Fermer</button>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block content %}

{%  if globalStatuses.ImportInProgress %}
    <div class="alert alert-warning">
        <strong>Attention</strong> une importation est en cours, il est déconseillé d'utiliser ArchiveTesDocs pendant ce processus !
        {% if ( userscale < 50 ) %}
            Pour en savoir plus vous pouvez accéder à la page de <a href="{{ path('bs_idp_archive_importsrapportsee') }}" class="btn btn-warning">résumé d'import</a>
        {%  endif %}
    </div>
{%  endif %}

<div class="atd-page-head">
    <h1>Tableau de bord</h1>
    <p>Vue d'ensemble de vos demandes d'archives</p>
</div>

{# Compteurs de demandes — id liNb*/badgeNb* conservés pour Dashboard.js (clic -> modale) #}
<div class="atd-stat-grid" id="listOperations">
    <div class="atd-stat-card btnlike" id="liNbTransfer">
        <div class="atd-icon-box {{ nbs[0] > 0 ? 'blue' : 'gray' }}"><i class="fal fa-paper-plane"></i></div>
        <div>
            <div class="atd-stat-label">{{ translations[2] }}</div>
            <div class="atd-stat-value {{ nbs[0] > 0 ? '' : 'zero' }}"><span class="badge" id="badgeNbTransfer">{{ nbs[0] }}</span></div>
        </div>
    </div>
    <div class="atd-stat-card btnlike" id="liNbConsult">
        <div class="atd-icon-box {{ nbs[1] > 0 ? 'gold' : 'gray' }}"><i class="fal fa-eye"></i></div>
        <div>
            <div class="atd-stat-label">{{ translations[3] }}</div>
            <div class="atd-stat-value {{ nbs[1] > 0 ? '' : 'zero' }}"><span class="badge" id="badgeNbConsult">{{ nbs[1] }}</span></div>
        </div>
    </div>
    <div class="atd-stat-card btnlike" id="liNbReturn">
        <div class="atd-icon-box {{ nbs[2] > 0 ? 'blue' : 'gray' }}"><i class="fal fa-undo"></i></div>
        <div>
            <div class="atd-stat-label">{{ translations[4] }}</div>
            <div class="atd-stat-value {{ nbs[2] > 0 ? '' : 'zero' }}"><span class="badge" id="badgeNbReturn">{{ nbs[2] }}</span></div>
        </div>
    </div>
    <div class="atd-stat-card btnlike" id="liNbExit">
        <div class="atd-icon-box {{ nbs[3] > 0 ? 'gold' : 'gray' }}"><i class="fal fa-sign-out-alt"></i></div>
        <div>
            <div class="atd-stat-label">{{ translations[5] }}</div>
            <div class="atd-stat-value {{ nbs[3] > 0 ? '' : 'zero' }}"><span class="badge" id="badgeNbExit">{{ nbs[3] }}</span></div>
        </div>
    </div>
    <div class="atd-stat-card btnlike" id="liNbDestroy">
        <div class="atd-icon-box {{ nbs[4] > 0 ? 'blue' : 'gray' }}"><i class="fal fa-trash-alt"></i></div>
        <div>
            <div class="atd-stat-label">{{ translations[6] }}</div>
            <div class="atd-stat-value {{ nbs[4] > 0 ? '' : 'zero' }}"><span class="badge" id="badgeNbDestroy">{{ nbs[4] }}</span></div>
        </div>
    </div>
    <div class="atd-stat-card btnlike" id="liNbReloc">
        <div class="atd-icon-box {{ nbs[5] > 0 ? 'gold' : 'gray' }}"><i class="fal fa-arrows-alt-h"></i></div>
        <div>
            <div class="atd-stat-label">{{ translations[27] }}</div>
            <div class="atd-stat-value {{ nbs[5] > 0 ? '' : 'zero' }}"><span class="badge" id="badgeNbReloc">{{ nbs[5] }}</span></div>
        </div>
    </div>
</div>

{# Actions utilisateur — 2 colonnes de cards #}
<div class="atd-actions-grid" id="btnactions">
    <div id="btnuser">
        <h3 class="atd-section-label">Créer une unité d'archives</h3>
        <div class="atd-action-list">
            <a class="atd-action-card" id="choice-create-ua" href="{{ path('bs_idp_archive_new') }}">
                <div class="atd-icon-box blue"><i class="fal fa-pen"></i></div>
                <div class="atd-action-label">Saisir une unité d'archives</div>
            </a>
            <a class="atd-action-card" id="choice-transfer-ua" href="{{ path('bs_idp_archive_transferscreen') }}">
                <div class="atd-icon-box blue"><i class="fal fa-paper-plane"></i></div>
                <div class="atd-action-label">Transférer une unité d'archives</div>
            </a>
            <a class="atd-action-card" id="choice-reloc-ua" href="{{ path('bs_idp_archive_askreloc_screen') }}">
                <div class="atd-icon-box blue"><i class="fal fa-map-marker-alt"></i></div>
                <div class="atd-action-label">Relocaliser une unité d'archives</div>
            </a>
        </div>
    </div>
    <div>
        <h3 class="atd-section-label">Opérations sur les archives</h3>
        <div class="atd-action-list">
            <a class="atd-action-card" id="consult-ua-choice" href="{{ path('bs_idp_archive_askconsult_screen') }}">
                <div class="atd-icon-box gold"><i class="fal fa-eye"></i></div>
                <div class="atd-action-label">{{ translations[14] }}</div>
            </a>
            <a class="atd-action-card" id="return-ua-choice" href="{{ path('bs_idp_archive_askreturn_screen') }}">
                <div class="atd-icon-box gold"><i class="fal fa-undo"></i></div>
                <div class="atd-action-label">{{ translations[16] }}</div>
            </a>
            <a class="atd-action-card" id="exit-ua-choice" href="{{ path('bs_idp_archive_askexit_screen') }}">
                <div class="atd-icon-box gold"><i class="fal fa-sign-out-alt"></i></div>
                <div class="atd-action-label">{{ translations[17] }}</div>
            </a>
            <a class="atd-action-card" id="delete-ua-choice" href="{{ path('bs_idp_archive_askdelete_screen') }}">
                <div class="atd-icon-box gold"><i class="fal fa-trash-alt"></i></div>
                <div class="atd-action-label">{{ translations[15] }}</div>
            </a>
        </div>
    </div>
</div>

{% if ( userscale < 100 ) %}

{# Cards archiviste — sous-liens à plat (fin des accordéons) #}
<div class="atd-admin-grid" id="btnarchivist">

    <div class="atd-admin-card" id="panel_manage_user_wants">
        <div class="atd-admin-icon"><i class="fal fa-users"></i></div>
        <div class="atd-admin-title">Gérer les demandes</div>
        <div id="manage-user-wants-choices" class="atd-admin-actions">
            <a id="choice-manage-userwants" href="{{ path('bs_idp_archivist_manage_user_wants') }}" class="btn btn-default">Demandes utilisateurs</a>
            <a id="choice-manage-providerwants" href="{{ path('bs_idp_archivist_manage_provider_wants') }}" class="btn btn-default">Demandes prestataires</a>
            <a id="choice-close-userwants" href="{{ path('bs_idp_archivist_close_user_wants') }}" class="btn btn-default">Clôturer</a>
        </div>
    </div>

    <div class="atd-admin-card" id="panel_follow_operations">
        <div class="atd-admin-icon"><i class="fal fa-clock"></i></div>
        <div class="atd-admin-title">Suivre les opérations</div>
        <div id="manage_follow_operations" class="atd-admin-actions">
            <a id="choice-manage-unlimited" href="{{ path('bs_idp_archivist_askunlimited_screen') }}" class="btn btn-default">Conservations illimitées</a>
        </div>
    </div>

    <div class="atd-admin-card" id="panel_manage_db">
        <div class="atd-admin-icon"><i class="fal fa-database"></i></div>
        <div class="atd-admin-title">{{ translations[22] }}</div>
        <div class="atd-admin-actions">
            <a href="{{ path('bs_idp_archivist_managedb_input_services') }}" class="btn btn-default">Paramétrer les référentiels</a>
        </div>
    </div>

</div>

{% endif %}

{% endblock %}

{% block javascripts %}
	{{ parent() }}
	<script type="text/javascript">
        var IDP_CONST = {
            bs_idp_userscale: '{{ userscale }}',
            bs_translations: '{{translations|json_encode|escape('js')|raw}}'
        };
        var JSON_URLS = {
            bs_idp_archive_detailled_information_ajax: "{{ path('bs_idp_archive_detailled_information_ajax')}}",
            bs_idp_export_all_offline: '{{ path("bs_idp_export_all_offline") }}',
            bs_core_userspace_userfile_viewmainscreen: '{{ path("bs_core_userspace_userfile_viewmainscreen") }}'
        };
    </script>
    {% javascripts
        '@bsIDPDashboardBundle/Resources/public/js/Dashboard.1.4.5.0.js'
        '@bsIDPArchiveBundle/Resources/public/js/IDPExport.1.4.5.0.js'
    %}
        <script src="{{ asset_url }}"></script>
    {% endjavascripts %}

{% endblock %}
