<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8" />
        <title>{% if headTranslations is defined %}{{ headTranslations[1] }} {% endif %}{% block title %}{% endblock %}</title>

        <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    	<meta content="" name="description" />
	    <meta content="" name="author" />
        {% block meta %}
        {% endblock %}

		{% block stylesheets %}
		    <link href="{{ asset('/css/bootstrap.css') }}" type="text/css" rel="stylesheet" />
		    <link href="{{ asset('/css/fontawesome-all.min.css') }}" type="text/css" rel="stylesheet" />
		    <link href="{{ asset('/css/color-scheme.css') }}" type="text/css" rel="stylesheet" />
		    <link href="{{ asset('/css/tutorialize.css') }}" type="text/css" rel="stylesheet" />
		    <link href="{{ asset('/css/main.css') }}" type="text/css" rel="stylesheet" />
		    <link href="{{ asset('/css/atd-theme.css') }}" type="text/css" rel="stylesheet" />
		    <link href="{{ asset('/css/print.css') }}" type="text/css" rel="stylesheet" media="print" />
		{% endblock %}

        <link rel="icon" type="image/x-icon" href="{{ asset('favicon.ico') }}" />
    </head>

<!-- BEGIN BODY -->
<body class="">

    {% block overlay %}{% endblock %}

	<!-- SHELL : SIDEBAR + CONTENU -->
	<div class="atd-shell">

		{% include 'atd-sidebar.html.twig' %}

		<!-- CONTENT SECTION -->
		<main class="atd-main" role="main">
			{% block content %}{% endblock %}

			<!-- FOOTER SECTION -->
			{% include 'footer.html.twig' %}
		</main>
		<!-- ENDOF CONTENT SECTION -->

	</div>
	<!-- ENDOF SHELL -->

		{% block javascripts %}
			<script src="{{ asset('/js/jquery-3.2.1.min.js') }}"></script>
			<script src="{{ asset('/js/jquery-ui.js') }}"></script>
			<script src="{{ asset('/js/bootstrap.js') }}"></script>
			<script src="{{ asset('/js/jquery.tutorialize.js') }}"></script>
			<script src="{{ asset('/js/bootbox.min.js') }}"></script>
			<script src="{{ asset('/js/IDPArchiveHeader.1.4.5.0.js') }}"></script>
		{% endblock %}
    </body>
</html>
